modules = ["nodejs-20", "python-3.12", "bash", "web", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
build = ["sh", "-c", "PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright pnpm install --frozen-lockfile && PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright pnpm run install:browser && PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright pnpm run verify:browser && pnpm run build"]
run = ["sh", "-c", "NODE_ENV=production PLAYWRIGHT_BROWSERS_PATH=.cache/ms-playwright pnpm run start:prod"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/api-server: API Server"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 80

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "8080"
API_PORT = "8080"
NODE_ENV = "development"
