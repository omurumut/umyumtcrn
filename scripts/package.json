{
  "name": "@workspace/scripts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "hello": "tsx ./src/hello.ts",
    "seed": "tsx ./src/seed.ts",
    "seed:internal": "tsx ./src/seed-internal.ts",
    "export:internal": "tsx ./src/export-internal.ts",
    "import:internal": "tsx ./src/import-internal.ts",
    "sync:mgm-degree-days": "tsx ./src/sync-mgm-degree-days.ts",
    "import:mgm": "tsx ./src/import-mgm.ts",
    "import:mgm-excel": "tsx ./src/import-mgm-excel.ts",
    "test:db:smoke": "tsx ./src/test-db.ts --smoke",
    "test:with-db": "tsx ./src/test-db.ts --with-child",
    "test:fixtures": "tsx ./src/test-db.ts --fixtures",
    "test:with-fixtures": "tsx ./src/test-db.ts --with-fixtures",
    "test:e2e": "tsx ./src/test-db.ts --with-fixtures -- node ./node_modules/tsx/dist/cli.mjs ./src/test-e2e.ts",
    "verify:browser": "tsx ./src/verify-browser.ts",
    "test:production-readiness": "tsx ./src/test-db.ts --with-fixtures -- node ./node_modules/tsx/dist/cli.mjs ./src/test-production-readiness.ts",
    "test:shared-auth": "tsx ./src/test-db.ts --with-fixtures -- node ./node_modules/tsx/dist/cli.mjs ./src/test-shared-auth.ts",
    "test:auth-migration-upgrade": "tsx ./src/test-db.ts --with-child -- node ./node_modules/tsx/dist/cli.mjs ./src/test-auth-migration-upgrade.ts",
    "test:audit": "tsx ./src/test-db.ts --with-fixtures -- node ./node_modules/tsx/dist/cli.mjs ./src/test-audit.ts",
    "test:audit-restore": "tsx ./src/test-db.ts --with-child -- node ./node_modules/tsx/dist/cli.mjs ./src/test-audit-restore.ts",
    "auth:cleanup": "tsx ./src/cleanup-auth-state.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/db": "workspace:*",
    "drizzle-orm": "catalog:",
    "exceljs": "^4.4.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "tsx": "catalog:"
  }
}
