{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm run typecheck && pnpm -r --filter \"!@workspace/mockup-sandbox\" --if-present run build",
    "start:prod": "pnpm --filter @workspace/api-server run start",
    "install:browser": "playwright install chromium",
    "verify:browser": "pnpm --filter @workspace/scripts run verify:browser",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "replit:check": "pnpm install --frozen-lockfile && pnpm run build",
    "replit:start": "pnpm --filter @workspace/api-server run dev",
    "replit:api": "pnpm --filter @workspace/api-server run dev",
    "replit:web": "pnpm --filter @workspace/ems-dashboard run dev",
    "test:db:smoke": "pnpm --filter @workspace/scripts run test:db:smoke",
    "test:with-db": "pnpm --filter @workspace/scripts run test:with-db",
    "test:fixtures": "pnpm --filter @workspace/scripts run test:fixtures",
    "test:with-fixtures": "pnpm --filter @workspace/scripts run test:with-fixtures",
    "test:e2e": "pnpm --filter @workspace/scripts run test:e2e",
    "test:production-readiness": "pnpm --filter @workspace/scripts run test:production-readiness",
    "test:operational-readiness": "pnpm --filter @workspace/scripts run test:operational-readiness",
    "test:db-push-guard": "pnpm --filter @workspace/scripts run test:db-push-guard",
    "test:mgm-file-import-guard": "pnpm --filter @workspace/scripts run test:mgm-file-import-guard",
    "test:operational-diagnostics": "pnpm --filter @workspace/scripts run test:operational-diagnostics",
    "test:report-migration-readiness": "pnpm --filter @workspace/scripts run test:report-migration-readiness",
    "test:report-archive-retention": "pnpm --filter @workspace/scripts run test:report-archive-retention",
    "test:report-storage-s3": "pnpm --filter @workspace/scripts run test:report-storage-s3",
    "test:report-storage-s3-smoke": "pnpm --filter @workspace/scripts run test:report-storage-s3-smoke",
    "test:proxy-pool": "pnpm --filter @workspace/scripts run test:proxy-pool",
    "test:shared-auth": "pnpm --filter @workspace/scripts run test:shared-auth",
    "test:auth-migration-upgrade": "pnpm --filter @workspace/scripts run test:auth-migration-upgrade",
    "test:audit": "pnpm --filter @workspace/scripts run test:audit",
    "test:audit-restore": "pnpm --filter @workspace/scripts run test:audit-restore",
    "test:equipment-inventory": "pnpm --filter @workspace/scripts run test:equipment-inventory",
    "test:equipment-custom-fields": "pnpm --filter @workspace/scripts run test:equipment-custom-fields",
    "test:equipment-import-export": "pnpm --filter @workspace/scripts run test:equipment-import-export",
    "test:equipment-context": "pnpm --filter @workspace/scripts run test:equipment-context",
    "test:ai-provider": "pnpm --filter @workspace/scripts run test:ai-provider",
    "test:ai-context-builder": "pnpm --filter @workspace/scripts run test:ai-context-builder",
    "test:ai-analysis-persistence": "pnpm --filter @workspace/scripts run test:ai-analysis-persistence",
    "test:ai-resilience": "pnpm --filter @workspace/scripts run test:ai-resilience",
    "test:ai-draft-action": "pnpm --filter @workspace/scripts run test:ai-draft-action",
    "test:ai-security-regression": "pnpm --filter @workspace/scripts run test:ai-security-regression",
    "test:gemini-smoke": "pnpm --filter @workspace/scripts run test:gemini-smoke",
    "verify:ci": "pnpm run typecheck && pnpm run build && pnpm run test:db:smoke && pnpm run test:fixtures && pnpm run test:audit && pnpm run test:audit-restore && pnpm run test:e2e && pnpm run test:production-readiness",
    "auth:cleanup": "pnpm --filter @workspace/scripts run auth:cleanup",
    "start": "ts-node scripts/index.ts",
    "dev": "ts-node-dev scripts/index.ts"
  },
  "private": true,
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@rollup/rollup-win32-x64-msvc": "^4.62.2",
    "@tailwindcss/oxide-win32-x64-msvc": "^4.3.2",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.61.1",
    "prettier": "^3.8.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "~5.9.3"
  }
}
